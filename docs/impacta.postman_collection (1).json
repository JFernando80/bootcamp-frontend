								"exec": [
									"const responseData = pm.response.json();",
									"",
									"pm.environment.set(\"token\", responseData.body.tokenDTO.token);",
									"pm.environment.set(\"refresh_token\", responseData.body.tokenDTO.refreshToken);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.sendRequest(\"http://localhost:8030/bootcamp/security/cadastro\", function (err, response) {",
									"    if (err) {",
									"        console.log(err);",
									"    } else {",
									"        pm.environment.set(\"token_security\", response.json().body.publicKey);",
									"        pm.environment.set(\"id_security\", response.json().body.id);",
									"    }",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
